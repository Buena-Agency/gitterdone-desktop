{
  "name": "gitterdone-desktop",
  "version": "1.0.0",
  "description": "Desktop shell for Gitterdone — a thin Electron wrapper around https://www.gitterdone.org that always loads the latest deployed web app.",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --mac",
    "pack": "electron-builder --dir"
  },
  "author": "Buena",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "pro.gitterdone.desktop",
    "productName": "Gitterdone",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
